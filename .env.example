# ====== SERVER ======
NODE_ENV=development
API_PORT=8081

# ====== DB (Postgres) ======
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=joya
POSTGRES_USER=joya
POSTGRES_PASSWORD=joya1234

# ====== Redis / BullMQ ======
REDIS_HOST=localhost
REDIS_PORT=6379

# ====== Storage ======
# MVP는 로컬 파일 저장을 기본으로 하고, MinIO는 옵션으로 포함합니다.
STORAGE_MODE=local  # local | minio
LOCAL_PDF_DIR=./storage/pdfs

# MinIO (optional)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=joya-pdfs

# ====== Fonts ======
# 임베딩 허용 폰트만 사용하세요(라이선스 확인 필수)
FONTS_DIR=./assets/fonts

# ====== Worker ======
WORKER_CONCURRENCY=2
