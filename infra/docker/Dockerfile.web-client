FROM node:20-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
COPY apps/web-client/package.json apps/web-client/package.json
RUN npm install
COPY apps/web-client apps/web-client
EXPOSE 3001
CMD ["npm", "--prefix", "apps/web-client", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3001"]
